# 环境变量样例配置（后端运行于腾讯云 CloudBase，不再依赖 Vercel / Supabase / Upstash）
#
# 部署到 CloudBase 时，以下变量通过 cloudbaserc.json 的 functions[].envVariables
# 以及 CloudBase 控制台注入到云函数运行时，无需在本地维护 .env。
# 本地联调时，可自行创建 .env 并填入相同变量（.env 已被 .gitignore 忽略）。

# --- CloudBase 环境 ---
CLOUDBASE_ENV_ID=jerrydecloud-d5g18hdmm34d7d90c

# --- 微信小程序端（前端 client/.env / client/.env.production 使用 VITE_ 前缀）---
WX_APP_ID=wx414c6b38efdb1735
WX_APP_SECRET=your_wx_app_secret

# --- 是否允许测试登录钩子（TEST_LOGIN）---
# 联调 / E2E 时设为 true；生产环境务必设为 false
ALLOW_TEST_LOGIN=true

# --- 前端生产基地址（client/.env.production）---
# 已部署的 CloudBase HTTP 云函数域名
VITE_BACKEND_URL=https://jerrydecloud-d5g18hdmm34d7d90c.service.tcloudbase.com
