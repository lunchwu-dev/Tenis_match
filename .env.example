# 这份是被正确更新的环境变量样例配置 (实际真值已配置在在您的真实 Vercel Dashboard 中)
# .env.local 会通过 vercel env pull 直接拉取
# 注意: 您需要把 schema.sql 的内容在以下 supabase 网址的控制台中执行一下

# --- Supabase Postgres 核心业务数据库 ---
SUPABASE_URL=https://leobryujqsqpzyvhxsxq.supabase.co
# 用于后端执行 Serverless 无视鉴权进行写入
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1Ni...

# --- Upstash Redis 缓存与分布式锁 ---
# 注意对应 Vercel 帮你自动生成的带有 KV_REST_API 尾缀的名称
UPSTASH_REDIS_REST_KV_REST_API_URL=https://star-ostrich-78863.upstash.io
UPSTASH_REDIS_REST_KV_REST_API_TOKEN=gQAAAAA...

# --- 微信小程序端 ---
VITE_WX_APP_ID=your_wx_app_id
VITE_BACKEND_URL=http://localhost:3000
