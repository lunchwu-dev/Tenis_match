# 后端环境变量配置示例
# 复制此文件为 .env.local 并填入真实值

# Supabase 配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis 配置
UPSTASH_REDIS_REST_KV_REST_API_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_KV_REST_API_TOKEN=your-redis-token

# 微信小程序配置
WX_APP_ID=wx your appid
WX_APP_SECRET=your app secret

# Cron 定时任务密钥
CRON_SECRET=your-cron-secret

# 端口（可选，默认 3000）
PORT=3000
